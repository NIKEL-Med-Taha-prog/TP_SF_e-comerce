{% extends 'base.html.twig' %}

{% block title %}Catégories - TechShop{% endblock %}

{% block body %}
<div class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Bienvenue sur TechShop</h1>
        <p class="lead">Trouvez les meilleurs produits dans toutes nos catégories.</p>
        <a href="{{ path('app_home') }}" class="btn btn-warning btn-lg me-2">Voir les produits</a>
        <a href="#categories" class="btn btn-outline-light btn-lg">Explorer les catégories</a>
    </div>
</div>

<div class="container mb-5" id="categories">
    <h2 class="fw-bold text-center mb-4">Nos Catégories</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for category in categories %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm text-center">
                    <div class="card-body py-4">
                        <span class="badge bg-warning text-dark mb-3">{{ category.products|length }} article(s)</span>
                        <h4 class="card-title">{{ category.name }}</h4>
                        <p class="text-muted">Explorez notre sélection {{ category.name | lower }}.</p>
                        <a href="{{ path('app_products_by_category', {'id': category.id}) }}" class="btn btn-dark">
                            Voir {{ category.name }}
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="lead text-muted">Aucune catégorie disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>

<div class="bg-light py-5">
    <div class="container text-center">
        <div class="row">
            <div class="col-md-4 mb-3">
                <h5>🚚 Livraison gratuite</h5>
                <p class="text-muted">Dès 50€ d'achat</p>
            </div>
            <div class="col-md-4 mb-3">
                <h5>🔒 Paiement sécurisé</h5>
                <p class="text-muted">Transactions 100% sécurisées</p>
            </div>
            <div class="col-md-4 mb-3">
                <h5>↩️ Retours faciles</h5>
                <p class="text-muted">Politique de retour 30 jours</p>
            </div>
        </div>
    </div>
</div>

<footer class="bg-dark text-white py-4 mt-5">
    <div class="container d-flex justify-content-between">
        <div>
            <h5>TechShop</h5>
            <p class="mb-0">Des produits de qualité à prix juste.</p>
        </div>
        <div class="text-end">
            <p class="mb-0">&copy; 2026 TechShop. Tous droits réservés.</p>
        </div>
    </div>
</footer>
{% endblock %}