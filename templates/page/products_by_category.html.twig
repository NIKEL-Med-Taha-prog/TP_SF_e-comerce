{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - TechShop{% endblock %}

{% block body %}
<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_browse_categories') }}">Catégories</a></li>
            <li class="breadcrumb-item active">{{ category.name }}</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4">{{ category.name }}</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="https://via.placeholder.com/300x200?text={{ product.name|url_encode }}" class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="text-muted small">
                            {{ product.description|length > 60 ? product.description|slice(0, 60) ~ '...' : product.description }}
                        </p>
                        <h5 class="text-success fw-bold">{{ product.prix }} €</h5>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <a href="{{ path('app_product_details', {'id': product.id}) }}" class="btn btn-outline-dark w-100">
                            Voir les détails
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="text-muted lead">Aucun produit dans cette catégorie.</p>
            </div>
        {% endfor %}
    </div>
</div>

<footer class="bg-dark text-white py-4 mt-5">
    <div class="container d-flex justify-content-between">
        <div>
            <h5>TechShop</h5>
            <p class="mb-0">Des produits de qualité à prix juste.</p>
        </div>
        <div class="text-end">
            <p class="mb-0">&copy; 2026 TechShop. Tous droits réservés.</p>
        </div>
    </div>
</footer>
{% endblock %}