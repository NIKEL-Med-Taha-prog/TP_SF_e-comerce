{% extends 'base.html.twig' %}

{% block title %}Accueil - TechShop{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4 fw-bold">🛍️ Tous nos produits</h1>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 border-0 shadow">
                    <img src="https://via.placeholder.com/300x200?text={{ product.name|url_encode }}" class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <span class="badge bg-secondary mb-2">{{ product.category.name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <h4 class="text-success fw-bold">{{ product.prix }} €</h4>
                        <a href="{{ path('app_product_details', {'id': product.id}) }}" class="btn btn-primary w-100 mt-2">
                            Voir le produit
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-muted text-center">Aucun produit disponible.</p>
        {% endfor %}
    </div>
</div>

<footer class="bg-dark text-white py-4 mt-5">
    <div class="container d-flex justify-content-between">
        <div>
            <h5>TechShop</h5>
            <p class="mb-0">Des produits de qualité à prix juste.</p>
        </div>
        <div class="text-end">
            <p class="mb-0">&copy; 2026 TechShop. Tous droits réservés.</p>
        </div>
    </div>
</footer>
{% endblock %}