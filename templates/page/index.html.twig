{% extends 'base.html.twig' %}

{% block title %}Products - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4">Our Products</h1>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">{{ product.name }}</h5>
                            <span class="badge bg-info">{{ product.category.name }}</span>
                        </div>
                        <h4 class="text-primary fw-bold">{{ product.prix }} €</h4>

                        <a href="{{ path('app_product_details', {'id': product.id}) }}" class="btn btn-outline-primary w-100 mt-3">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-center">Aucun produit trouvé en base de données.</p>
        {% endfor %}
    </div>
</div>

<footer class="bg-dark text-white mt-5 py-4">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <h5>Our Store</h5>
                <p>Quality products at affordable prices</p>
            </div>
            <div class="col-md-6 text-md-end">
                <p>&copy; 2026 Our Store. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>
{% endblock %}
