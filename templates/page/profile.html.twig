{% extends 'base.html.twig' %}

{% block title %}Mon Profil - TechShop{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="mb-3 fs-1">👤</div>
                <h5>{{ app.user.email }}</h5>
                <hr>
                <ul class="list-unstyled text-start">
                    <li class="mb-2"><a href="#info" class="text-decoration-none">Mes informations</a></li>
                    <li class="mb-2"><a href="#orders" class="text-decoration-none">Mes commandes</a></li>
                    <li class="mb-2"><a href="{{ path('app_logout') }}" class="text-danger text-decoration-none">Se déconnecter</a></li>
                </ul>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm mb-4" id="info">
                <div class="card-header bg-warning text-dark fw-bold">
                    Mes informations
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Adresse e-mail :</label>
                            <p>{{ app.user.email }}</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Rôle :</label>
                            <p>{{ app.user.roles|join(', ') }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm" id="orders">
                <div class="card-header bg-warning text-dark fw-bold">
                    Historique des commandes
                </div>
                <div class="card-body text-muted text-center py-5">
                    <p class="lead">Aucune commande pour le moment.</p>
                    <a href="{{ path('app_browse_categories') }}" class="btn btn-warning">Commencer les achats</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}