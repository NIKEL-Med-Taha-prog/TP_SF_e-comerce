{% extends 'base.html.twig' %}

{% block title %}Mon Panier - TechShop{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="fw-bold mb-4">🛒 Mon Panier</h1>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <table class="table align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Produit</th>
                                <th>Prix unitaire</th>
                                <th>Quantité</th>
                                <th>Sous-total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in cart.cartItems %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="https://via.placeholder.com/70" class="rounded" alt="{{ item.product.name }}">
                                            <div>
                                                <strong>{{ item.product.name }}</strong>
                                                <div class="text-muted small">#{{ item.product.id }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>{{ item.price }} €</td>
                                    <td>{{ item.quantity }}</td>
                                    <td class="fw-bold text-success">{{ item.price * item.quantity }} €</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <p class="lead">Votre panier est vide.</p>
                                        <a href="{{ path('app_browse_categories') }}" class="btn btn-warning">Commencer les achats</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <a href="{{ path('app_browse_categories') }}" class="btn btn-outline-secondary">← Continuer les achats</a>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark fw-bold">
                    Récapitulatif de commande
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Sous-total</span>
                        <span>{{ cart.total() }} €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Livraison</span>
                        <span class="text-success">Gratuite</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span class="text-success">{{ cart.total() }} €</span>
                    </div>
                    <div class="d-grid mt-3">
                        <button class="btn btn-warning btn-lg fw-bold">Passer la commande</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="bg-dark text-white py-4 mt-5">
    <div class="container d-flex justify-content-between">
        <div>
            <h5>TechShop</h5>
            <p class="mb-0">Des produits de qualité à prix juste.</p>
        </div>
        <div class="text-end">
            <p class="mb-0">&copy; 2026 TechShop. Tous droits réservés.</p>
        </div>
    </div>
</footer>
{% endblock %}